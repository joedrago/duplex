{
    "name": "duplex-web",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Tooling-only package for formatting and linting duplex's web/ assets.",
    "scripts": {
        "format": "prettier --write .",
        "lint": "eslint ."
    },
    "devDependencies": {
        "@eslint/js": "^9.15.0",
        "eslint": "^9.15.0",
        "globals": "^15.12.0",
        "prettier": "^3.3.3"
    },
    "prettier": {
        "printWidth": 130,
        "tabWidth": 4,
        "trailingComma": "none",
        "semi": false
    }
}
